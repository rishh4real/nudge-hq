                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/departments"
          }
        },
        {
          "name": "Create Department",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
