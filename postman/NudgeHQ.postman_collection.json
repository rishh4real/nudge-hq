{
  "info": {
    "name": "NudgeHQ API",
    "description": "Local API collection for NudgeHQ auth, employee, admin, analytics, task, and AI workflows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "API Root",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('adminToken', json.token);",
                  "if (json.user?.id) pm.environment.set('adminId', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('employeeToken', json.token);",
                  "if (json.user?.id) pm.environment.set('employeeId', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{employeeEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Signup User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo.user@example.com\",\n  \"password\": \"nudgehq123\",\n  \"role\": \"employee\",\n  \"department_id\": \"{{departmentId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/signup"
          }
        }
      ]
    },
    {
      "name": "Employee",
      "item": [
        {
          "name": "Employee Dashboard",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/employees/dashboard"
          }
        },
        {
          "name": "My Updates",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/employees/updates"
          }
        },
        {
          "name": "Submit Progress Update",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"task_id\": \"{{taskId}}\",\n  \"progress_text\": \"Completed the latest NudgeHQ check-in from Postman.\",\n  \"proof_link\": \"https://example.com/proof\"\n}"
            },
            "url": "{{baseUrl}}/api/employees/updates"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.task?.id) pm.environment.set('taskId', json.task.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman demo task\",\n  \"description\": \"Created from the NudgeHQ Postman collection.\",\n  \"status\": \"todo\",\n  \"assignee_id\": \"{{employeeId}}\",\n  \"due_date\": \"2026-06-01T10:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}/status"
          }
        },
        {
          "name": "Mark Task Blocked",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{employeeToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"blocked\",\n  \"blocker_text\": \"Need manager approval before moving forward.\"\n}"
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}/status"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Departments",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
