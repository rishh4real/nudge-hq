                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman QA Team\",\n  \"description\": \"Temporary department created from Postman.\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/departments"
          }
        },
        {
          "name": "All Employee Updates",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/updates"
          }
        },
        {
          "name": "Export Reports",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/reports/export"
          }
        }
      ]
    },
