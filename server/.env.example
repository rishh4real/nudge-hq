PORT=5000
NODE_ENV=development
TRUST_PROXY=0
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
REQUEST_BODY_LIMIT=200kb
GENERAL_RATE_LIMIT_WINDOW_MS=900000
GENERAL_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=60
CONTACT_RATE_LIMIT_WINDOW_MS=3600000
CONTACT_RATE_LIMIT_MAX=10
NOTIFY_RATE_LIMIT_WINDOW_MS=900000
NOTIFY_RATE_LIMIT_MAX=40

# JWT Secret for authenticating routes
JWT_SECRET=super_secret_nudgehq_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Supabase Configurations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-or-anon-key

# Groq AI SDK Key for summaries and anomaly identification
GROQ_API_KEY=gsk_your_groq_api_key_goes_here
GROQ_MODEL=llama-3.3-70b-versatile

# Email automation for verification, invites, and password reset
# For Gmail, SMTP_PASS must be a Google App Password, not your normal Gmail password.
CLIENT_URL=http://127.0.0.1:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello.nudgehq@gmail.com
SMTP_PASS=your-google-app-password
MAIL_FROM=hello.nudgehq@gmail.com

# Twilio WhatsApp notifications
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

